TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=
TELEGRAM_ALLOWED_CHAT_ID=
XAI_API_KEY=
AI_COUNCIL_DRY_SEND=false
# L4.100 channel policy: iMessage primary (phone-number thread), Telegram fallback
AI_COUNCIL_IMESSAGE_PRIMARY=true
# Comma-separated handles the HOST accepts from the bridge (e.g. +48600100200,me@icloud.com).
# Empty = legacy open mode (bridge-side thread filter is the only gate).
AI_COUNCIL_IMESSAGE_ALLOWED_SENDERS=
# Pending outbox rows older than this many seconds => bridge considered dead, fall back to Telegram
AI_COUNCIL_IMESSAGE_STALE_S=600
# Cost ledger day-shard retention (audit 1.3); 0 disables pruning
AI_COUNCIL_COSTS_RETENTION_DAYS=90
# L4.101 self-repair loop: proposes ONLY (apply gated behind /approve)
AI_COUNCIL_SELF_REPAIR=true
AI_COUNCIL_SELF_REPAIR_FILES=ai_council.py,tests/
AI_COUNCIL_SELF_REPAIR_MAX_BLOCKS=6
AI_COUNCIL_SELF_REPAIR_TIMEOUT=300
AI_COUNCIL_SELF_REPAIR_TEST_TIMEOUT=900
GROK_DAILY_BUDGET_USD=5
GROK_DAILY_CALL_LIMIT=200
AI_COUNCIL_CLAUDE_FLOW_MODEL=claude-opus-4-8
AI_COUNCIL_CLAUDE_FLOW_PERMISSION_MODE=plan
AI_COUNCIL_CLAUDE_FLOW_TIMEOUT=1800
AI_COUNCIL_STT_URL=https://api.x.ai/v1/stt
AI_COUNCIL_STT_LANGUAGE=pl
AI_COUNCIL_STT_FORMAT=true
AI_COUNCIL_STT_KEYTERMS=Bartek,Codex,Claude,Grok,AI Council,OpenClaw,Poke
AI_COUNCIL_STT_MAX_BYTES=25000000
AI_COUNCIL_STT_MAX_CHARS=8000
AI_COUNCIL_MEDIA_AUTO_ROUTE=true
AI_COUNCIL_MEDIA_INTENT_MAX_CHARS=3000
AI_COUNCIL_SHORTCUT_TOKEN=
AI_COUNCIL_SHORTCUT_HOST=127.0.0.1
AI_COUNCIL_SHORTCUT_PORT=8788
AI_COUNCIL_SHORTCUT_SEND_TELEGRAM=true
AI_COUNCIL_SHORTCUT_MAX_BODY_BYTES=25000000
AI_COUNCIL_CODEX_WORKER_MODEL=codex-5.3-spark
AI_COUNCIL_CODEX_WORKER_FALLBACK_MODEL=codex-5.3
AI_COUNCIL_CODEX_WORKER_SANDBOX=workspace-write
AI_COUNCIL_CODEX_WORKER_ENABLED=false
AI_COUNCIL_CODEX_WORKER_TIMEOUT=1800
AI_COUNCIL_CODEX_WORKER_RESEARCH_MAX_CHARS=10000
AI_COUNCIL_CODEX_WORKER_CLAUDE_INPUT_MAX_CHARS=16000
AI_COUNCIL_FRONT_QUALITY_GUARD=true
AI_COUNCIL_FRONT_QUALITY_MAX_CHARS=2400
AI_COUNCIL_FRONT_QUALITY_MAX_COMMAND_LINES=6
